# Server Configuration
PORT=3002
NODE_ENV=development

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin credentials (only used for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@hr.com

# CORS Origin (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# Database Mode: 'json' or 'supabase'
DATABASE_MODE=json

# Supabase Configuration (required if DATABASE_MODE=supabase)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
